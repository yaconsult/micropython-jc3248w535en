+# ESP32_Display_Panel configuration for JC3248W535EN (AXS15231B QSPI)
+# Unset FILE_SKIP flags so the .h conf files are used instead of Kconfig defaults.
+# IDF sdkconfig.defaults syntax: "# CONFIG_X is not set" disables a bool that defaults to y.
+# CONFIG_ESP_PANEL_DRIVERS_FILE_SKIP is not set
+# CONFIG_ESP_PANEL_BOARD_FILE_SKIP is not set
+# CONFIG_ESP_UTILS_CONF_FILE_SKIP is not set
