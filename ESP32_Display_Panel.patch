@@ -77,7 +193,14 @@ static MP_DEFINE_CONST_DICT(board_locals_dict, locals_dict_table);
 static mp_obj_t make_new(const mp_obj_type_t *type, size_t n_args, size_t n_kw, const mp_obj_t *args)
