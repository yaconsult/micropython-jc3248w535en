+    { MP_ROM_QSTR(MP_QSTR_draw_bitmap), MP_ROM_PTR(&board_draw_bitmap_func_obj) },
+    { MP_ROM_QSTR(MP_QSTR_read_touch), MP_ROM_PTR(&board_read_touch_func_obj) },
 };
